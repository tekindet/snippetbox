{{ template "base" .}}

{{define "title"}}{{.User.Name}}'s Profile{{end}}

{{define "body"}}
    <div class="profile">
        <h2>{{.User.Name}}</h2>
        <p>Email: {{.User.Email}}</p>
        <p>Member since: {{humanDate .User.Created}}</p>
    </div>

    <h3>Recent Snippets</h3>
    {{if .Snippets}}
        <table>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Created</th>
                <th>Tags</th>
            </tr>
            {{range .Snippets}}
            <tr>
                <td><a href="/snippets/{{.ID}}">#{{.ID}}</a></td>
                <td><a href="/snippets/{{.ID}}">{{.Title}}</a></td>
                <td>{{humanDate .Created}}</td>
                <td>
                    {{range .Tags}}
                        <a href="/tags/{{.Name}}">{{.Name}}</a>
                    {{end}}
                </td>
            </tr>
            {{end}}
        </table>
    {{else}}
        <p>No snippets yet.</p>
    {{end}}
{{end}}
